#!/usr/bin/env python3
# scripts/run-privileged
# Privileged execution: any bash command with secrets
# Usage: scripts/run-privileged pytest -x -m integration
#        scripts/run-privileged npm test
#        scripts/run-privileged echo "hello with secrets"

import os
import sys
import json
import socket

SOCKET = os.environ.get("SOCKET_PATH")
if not SOCKET:
    print("error: SOCKET_PATH not set", file=sys.stderr)
    print("The host must pass -e SOCKET_PATH to the container.", file=sys.stderr)
    sys.exit(1)

# Read command from arguments (everything after script name)
command = sys.argv[1:]
if not command:
    print("error: no command provided", file=sys.stderr)
    print("Usage: scripts/run-privileged <command> [args...]", file=sys.stderr)
    sys.exit(1)

payload = json.dumps({
    "action": "bash",
    "command": command
}).encode()

try:
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
        sock.connect(SOCKET)
        sock.sendall(
            b"POST / HTTP/1.1\r\n"
            b"Host: localhost\r\n"
            b"Content-Type: application/json\r\n"
            b"Content-Length: " + str(len(payload)).encode() + b"\r\n"
            b"\r\n" +
            payload
        )
        
        response = b""
        while True:
            chunk = sock.recv(4096)
            if not chunk:
                break
            response += chunk
        
        # Parse HTTP response
        header_end = response.find(b"\r\n\r\n")
        if header_end != -1:
            body = response[header_end + 4:]
            print(body.decode())
        else:
            print(response.decode())
            
except Exception as e:
    print(f"error: sidecar not running on {SOCKET}", file=sys.stderr)
    print("Run on host: ocreload", file=sys.stderr)
    sys.exit(1)
