#!/usr/bin/env python3
# scripts/run-ssh
# SSH to remote server via the sidecar (agent never sees SSH keys)
# Usage: scripts/run-ssh <host> <command...>
#        scripts/run-ssh server1 tail -50 /var/log/app
#        scripts/run-ssh server1 systemctl status nginx

import os
import sys
import json
import socket

SOCKET = os.environ.get("SOCKET_PATH")
if not SOCKET:
    print("error: SOCKET_PATH not set", file=sys.stderr)
    print("The host must pass -e SOCKET_PATH to the container.", file=sys.stderr)
    sys.exit(1)

if len(sys.argv) < 3:
    print("error: host and command required", file=sys.stderr)
    print("Usage: scripts/run-ssh <host> <command> [args...]", file=sys.stderr)
    sys.exit(1)

host = sys.argv[1]
command = sys.argv[2:]

payload = json.dumps({
    "action": "ssh",
    "host": host,
    "command": command
}).encode()

try:
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
        sock.connect(SOCKET)
        sock.sendall(
            b"POST / HTTP/1.1\r\n"
            b"Host: localhost\r\n"
            b"Content-Type: application/json\r\n"
            b"Content-Length: " + str(len(payload)).encode() + b"\r\n"
            b"\r\n" +
            payload
        )

        response = b""
        while True:
            chunk = sock.recv(4096)
            if not chunk:
                break
            response += chunk

        header_end = response.find(b"\r\n\r\n")
        if header_end != -1:
            body = response[header_end + 4:]
            print(body.decode())
        else:
            print(response.decode())

except Exception as e:
    print(f"error: sidecar not running on {SOCKET}", file=sys.stderr)
    print("Run on host: ocreload", file=sys.stderr)
    sys.exit(1)
